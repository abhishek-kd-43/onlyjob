<script>
/* ── DASHBOARD TABS ── */
function showDashTab(tab, btn) {
  document.getElementById('dashboard').style.display = tab==='overview' ? 'block' : 'none';
  document.getElementById('tab-documents').style.display = tab==='documents' ? 'block' : 'none';
  document.getElementById('tab-settings').style.display = tab==='settings' ? 'block' : 'none';

  if (btn) {
    document.querySelectorAll('.dash-tab').forEach(function(b){b.classList.remove('act');});
    btn.classList.add('act');
  } else {
    document.querySelectorAll('.dash-tab').forEach(function(b,i){
      b.classList.toggle('act', (i===0&&tab==='overview')||(i===1&&tab==='documents')||(i===2&&tab==='settings'));
    });
  }

  if (tab === 'documents') renderDocuments();
  if (tab === 'settings') loadSettings();
}

/* ── DOCUMENT LOCKER ── */
var DOC_CATEGORIES = {
  certificate: {label:'Certificate', color:'#059669', bg:'#ECFDF5', icon:'🏆'},
  marksheet:   {label:'Marksheet',   color:'#1D4ED8', bg:'#EFF6FF', icon:'📋'},
  id:          {label:'ID Proof',    color:'#7C3AED', bg:'#F5F3FF', icon:'🪪'},
  photo:       {label:'Photo',       color:'#E85D04', bg:'#FFF3EB', icon:'📸'},
  other:       {label:'Other',       color:'#6B7280', bg:'#F7F8FC', icon:'📄'},
};

var CHECKLIST_DOCS = [
  '10th Marksheet','12th Marksheet','Graduation Certificate','Aadhar Card',
  'PAN Card','Passport Photo','Caste Certificate','Income Certificate',
  'Domicile Certificate','NCC / NSS Certificate','Character Certificate',
];

var docFilter = 'all';

function getDocs() {
  var user = getCurrentUser();
  if (!user) return [];
  return JSON.parse(localStorage.getItem('oj_docs_'+user.email) || '[]');
}

function saveDocs(docs) {
  var user = getCurrentUser();
  if (!user) return;
  localStorage.setItem('oj_docs_'+user.email, JSON.stringify(docs));
  document.getElementById('ds-docs').textContent = docs.length;
}

function handleDocDrop(e) {
  e.preventDefault();
  document.getElementById('docUploadZone').style.borderColor = 'var(--border)';
  document.getElementById('docUploadZone').style.background = 'var(--bg2)';
  uploadDocs(e.dataTransfer.files);
}

function uploadDocs(files) {
  var docs = getDocs();
  var processed = 0;
  Array.from(files).forEach(function(file) {
    if (docs.length >= 20) { showToast('Maximum 20 documents allowed!', false); return; }
    if (file.size > 5 * 1024 * 1024) { showToast(file.name + ' is too large (max 5MB)', false); return; }
    var reader = new FileReader();
    reader.onload = function(e) {
      var ext = file.name.split('.').pop().toLowerCase();
      var cat = ext==='pdf'?'other':['jpg','jpeg','png'].includes(ext)?'photo':'other';
      docs.push({
        id: Date.now() + Math.random(),
        name: file.name,
        size: file.size,
        type: file.type,
        ext: ext,
        category: cat,
        dataUrl: e.target.result,
        uploadedAt: new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})
      });
      saveDocs(docs);
      processed++;
      if (processed === files.length) {
        showToast(files.length + ' document(s) uploaded!');
        renderDocuments();
      }
    };
    reader.readAsDataURL(file);
  });
}

function renderDocuments() {
  var docs = getDocs();
  var filtered = docFilter==='all' ? docs : docs.filter(function(d){return d.category===docFilter;});
  var list = document.getElementById('docList');
  var empty = document.getElementById('docEmpty');

  if (!filtered.length) {
    list.innerHTML = '';
    empty.style.display = 'block';
  } else {
    empty.style.display = 'none';
    var html = '';
    filtered.forEach(function(doc) {
      var cat = DOC_CATEGORIES[doc.category] || DOC_CATEGORIES.other;
      var sz = doc.size > 1024*1024 ? (doc.size/1024/1024).toFixed(1)+' MB' : Math.round(doc.size/1024)+' KB';
      var isImg = ['jpg','jpeg','png'].includes(doc.ext);
      html += '<div class="doc-item">'
        + '<div class="doc-icon" style="background:'+cat.bg+';">'+cat.icon+'</div>'
        + '<div class="doc-info">'
        + '<div class="doc-name">'+doc.name+'</div>'
        + '<div class="doc-meta">'+sz+' · Uploaded '+doc.uploadedAt+'</div>'
        + '<span class="doc-cat-badge" style="background:'+cat.bg+';color:'+cat.color+';">'+cat.label+'</span>'
        + '</div>'
        + '<div style="display:flex;align-items:center;gap:5px;">'
        + '<select onchange="changeDocCat(\''+doc.id+'\',this.value)" style="padding:5px 8px;border:1.5px solid var(--border);border-radius:6px;font-size:11px;font-family:Figtree,sans-serif;outline:none;">'
        + Object.keys(DOC_CATEGORIES).map(function(k){ return '<option value="'+k+'"'+(doc.category===k?' selected':'')+'>'+DOC_CATEGORIES[k].label+'</option>'; }).join('')
        + '</select>'
        + (isImg?'<button class="doc-btn doc-btn-view" onclick="viewDoc(\''+doc.id+'\')">👁</button>':'')
        + '<button class="doc-btn doc-btn-dl" onclick="downloadDoc(\''+doc.id+'\')">⬇</button>'
        + '<button class="doc-btn doc-btn-del" onclick="deleteDoc(\''+doc.id+'\')">🗑</button>'
        + '</div></div>';
    });
    list.innerHTML = html;
  }

  // Render checklist
  var docs2 = getDocs();
  var docNames = docs2.map(function(d){return d.name.toLowerCase();});
  var chkHtml = CHECKLIST_DOCS.map(function(item){
    var found = docNames.some(function(n){return n.includes(item.toLowerCase().split(' ')[0]);});
    return '<div class="chk-item '+(found?'done':'pending')+'">'
      + '<span style="font-size:14px;">'+(found?'✅':'⬜')+'</span>'
      + '<span>'+item+'</span>'
      + (found?'':' <button onclick="document.getElementById(\'docFileInput\').click()" style="margin-left:auto;padding:3px 9px;background:var(--accent-light);color:var(--accent-dark);border:none;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:Figtree,sans-serif;">Upload</button>')
      + '</div>';
  }).join('');
  document.getElementById('checklistItems').innerHTML = chkHtml;
}

function changeDocCat(docId, newCat) {
  var docs = getDocs();
  var doc = docs.find(function(d){return String(d.id)===String(docId)||d.id===parseFloat(docId);});
  if (doc) { doc.category = newCat; saveDocs(docs); renderDocuments(); }
}

function viewDoc(docId) {
  var docs = getDocs();
  var doc = docs.find(function(d){return String(d.id)===String(docId)||d.id===parseFloat(docId);});
  if (!doc) return;
  var win = window.open('', '_blank');
  win.document.write('<html><head><title>'+doc.name+'</title><style>body{margin:0;background:#000;display:flex;align-items:center;justify-content:center;min-height:100vh;}img{max-width:100vw;max-height:100vh;object-fit:contain;}</style></head><body><img src="'+doc.dataUrl+'"/></body></html>');
}

function downloadDoc(docId) {
  var docs = getDocs();
  var doc = docs.find(function(d){return String(d.id)===String(docId)||d.id===parseFloat(docId);});
  if (!doc) return;
  var a = document.createElement('a');
  a.href = doc.dataUrl;
  a.download = doc.name;
  a.click();
  showToast('Downloading: ' + doc.name);
}

function deleteDoc(docId) {
  if (!confirm('Delete this document?')) return;
  var docs = getDocs();
  docs = docs.filter(function(d){return String(d.id)!==String(docId)&&d.id!==parseFloat(docId);});
  saveDocs(docs);
  renderDocuments();
  showToast('Document deleted.');
}

function filterDocs(cat, btn) {
  docFilter = cat;
  if (btn) {
    document.querySelectorAll('#docCatFilter button').forEach(function(b){
      b.style.background='#fff'; b.style.color='var(--muted)'; b.style.borderColor='var(--border)';
    });
    btn.style.background='var(--accent)'; btn.style.color='#fff'; btn.style.borderColor='var(--accent)';
  }
  renderDocuments();
}

/* ── SETTINGS ── */
function loadSettings() {
  var user = getCurrentUser();
  if (!user) return;
  document.getElementById('set_fname').value = user.fname || '';
  document.getElementById('set_lname').value = user.lname || '';
  document.getElementById('set_exam').value = user.exam || 'Multiple Exams';
}

function saveSettings() {
  var user = getCurrentUser();
  if (!user) return;
  user.fname = document.getElementById('set_fname').value;
  user.lname = document.getElementById('set_lname').value;
  user.exam = document.getElementById('set_exam').value;
  var users = getUsers();
  var idx = users.findIndex(function(u){return u.email===user.email;});
  if (idx>=0) { users[idx]=user; saveUsers(users); }
  setCurrentUser(user);
  showToast('Settings saved!');
  document.getElementById('dash-name').textContent = user.fname+(user.lname?' '+user.lname:'');
}

function deleteAccount() {
  if (!confirm('DELETE account? This cannot be undone!')) return;
  var user = getCurrentUser();
  if (!user) return;
  var users = getUsers().filter(function(u){return u.email!==user.email;});
  saveUsers(users);
  localStorage.removeItem('oj_current_user');
  localStorage.removeItem('oj_docs_'+user.email);
  localStorage.removeItem('oj_scores_'+user.email);
  location.reload();
}

/* ── OVERRIDE showDashboard to use tabs ── */
var _origShowDash = showDashboard;
showDashboard = function(user) {
  document.getElementById('auth-tabs').style.display='none';
  document.getElementById('form-login').className='auth-form';
  document.getElementById('form-signup').className='auth-form';
  document.getElementById('dash-tabs').style.display='flex';
  showDashTab('overview', null);
  document.getElementById('dashboard').style.display='block';

  var initials=(user.fname[0]+(user.lname?user.lname[0]:'')).toUpperCase();
  if(user.picture){
    document.getElementById('dash-av').innerHTML='<img src="'+user.picture+'" style="width:52px;height:52px;border-radius:50%;object-fit:cover;"/>';
    document.getElementById('dash-av').style.background='none';
  } else {
    document.getElementById('dash-av').textContent=initials;
  }
  document.getElementById('dash-name').textContent=user.fname+(user.lname?' '+user.lname:'');
  document.getElementById('dash-sub').textContent=(user.exam||'Aspirant')+' · '+(user.state||'India')+' · Joined '+user.joined;
  var docs = JSON.parse(localStorage.getItem('oj_docs_'+user.email)||'[]');
  document.getElementById('ds-docs').textContent = docs.length;
  loadScores();
};

var _origLogout = doLogout;
doLogout = function() {
  localStorage.removeItem('oj_current_user');
  document.getElementById('auth-tabs').style.display='flex';
  document.getElementById('dash-tabs').style.display='none';
  document.getElementById('dashboard').style.display='none';
  document.getElementById('tab-documents').style.display='none';
  document.getElementById('tab-settings').style.display='none';
  switchTab('login');
  showToast('Logged out successfully.');
};
</script>
