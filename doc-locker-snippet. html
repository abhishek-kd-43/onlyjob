<style>
/* DASH TABS */
.dash-tabs{display:flex;background:var(--bg2);border-radius:10px;padding:4px;margin-bottom:20px;}
.dash-tab{flex:1;padding:9px 6px;text-align:center;border:none;background:transparent;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;border-radius:7px;transition:all .2s;font-family:'Figtree',sans-serif;}
.dash-tab.act{background:#fff;color:var(--dark);box-shadow:0 1px 4px rgba(0,0,0,0.1);}
.dash-tab:hover:not(.act){color:var(--dark);}

/* DOC ITEMS */
.doc-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:#fff;border:1.5px solid var(--border);border-radius:10px;margin-bottom:8px;transition:all .15s;}
.doc-item:hover{border-color:var(--accent);box-shadow:0 2px 8px rgba(232,93,4,.08);}
.doc-icon{width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.doc-info{flex:1;min-width:0;}
.doc-name{font-size:13px;font-weight:700;color:var(--dark);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.doc-meta{font-size:11px;color:var(--muted);margin-top:2px;}
.doc-cat-badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;margin-top:3px;display:inline-block;}
.doc-actions{display:flex;gap:6px;flex-shrink:0;}
.doc-btn{padding:5px 10px;border-radius:6px;font-size:11.5px;font-weight:700;cursor:pointer;border:none;font-family:'Figtree',sans-serif;}
.doc-btn-dl{background:var(--green-light);color:var(--green);}
.doc-btn-del{background:var(--red-light);color:var(--red);}
.doc-btn-view{background:var(--blue-light);color:var(--blue);}

/* CHECKLIST */
.chk-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;margin-bottom:4px;font-size:13px;}
.chk-item.done{color:var(--green);}
.chk-item.pending{color:var(--muted);}
</style>

