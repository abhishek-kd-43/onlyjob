      <button style="padding:5px 12px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:#fff;color:var(--muted);font-family:'Figtree',sans-serif;" onclick="filterDocs('certificate',this)">Certificates</button>
      <button style="padding:5px 12px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:#fff;color:var(--muted);font-family:'Figtree',sans-serif;" onclick="filterDocs('marksheet',this)">Marksheets</button>
      <button style="padding:5px 12px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:#fff;color:var(--muted);font-family:'Figtree',sans-serif;" onclick="filterDocs('id',this)">ID Proof</button>
      <button style="padding:5px 12px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:#fff;color:var(--muted);font-family:'Figtree',sans-serif;" onclick="filterDocs('photo',this)">Photos</button>
      <button style="padding:5px 12px;border:1.5px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;background:#fff;color:var(--muted);font-family:'Figtree',sans-serif;" onclick="filterDocs('other',this)">Other</button>
    </div>

    <!-- Doc List -->
    <div id="docList"></div>
    <div id="docEmpty" style="text-align:center;padding:30px;color:var(--muted);font-size:13px;display:none;">
      📭 No documents yet. Upload your first document above!
    </div>
  </div>

  <!-- Quick Upload Templates -->
