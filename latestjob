<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --accent:#E85D04;--al:#FFF3EB;--ad:#C44D00;
  --dark:#1A1A2E;--text:#2D2D3A;--muted:#6B7280;
  --border:#E8EAF0;--bg:#fff;--bg2:#F7F8FC;--bg3:#F0F2F8;
  --green:#059669;--gl:#ECFDF5;
  --blue:#1D4ED8;--bl:#EFF6FF;
  --purple:#7C3AED;--pl:#F5F3FF;
  --red:#DC2626;--rl:#FEF2F2;
  --r:10px;
}
html{scroll-behavior:smooth;}
body{font-family:'Figtree',sans-serif;color:var(--text);background:var(--bg3);font-size:15px;line-height:1.6;}

/* ── NAV ── */
header{background:#fff;border-bottom:1.5px solid var(--border);position:sticky;top:0;z-index:100;}
.nav-inner{max-width:1280px;margin:0 auto;padding:0 24px;display:flex;align-items:center;gap:14px;height:62px;}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0;}
.logo-icon{width:36px;height:36px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;}
.logo-icon svg{width:20px;height:20px;fill:#fff;}
.logo-text{font-family:'Syne',sans-serif;font-weight:800;font-size:20px;color:var(--dark);}
.logo-text span{color:var(--accent);}
nav{display:flex;gap:4px;margin-left:12px;}
nav a{font-size:13px;font-weight:500;color:var(--muted);text-decoration:none;padding:6px 11px;border-radius:6px;white-space:nowrap;transition:all .15s;}
nav a:hover{background:var(--al);color:var(--ad);}
nav a.act{background:var(--accent);color:#fff;}
.nav-right{margin-left:auto;display:flex;gap:8px;align-items:center;}
.nav-search-box{display:flex;border:1.5px solid var(--border);border-radius:8px;overflow:hidden;}
.nav-search-box input{padding:7px 13px;font-size:13px;border:none;outline:none;width:200px;font-family:'Figtree',sans-serif;}
.nav-search-box button{background:var(--accent);color:#fff;border:none;padding:7px 14px;cursor:pointer;font-size:13px;font-weight:600;}
@media(max-width:900px){nav{display:none;}.nav-search-box input{width:140px;}}

/* ── TICKER ── */
.ticker{background:var(--al);border-bottom:1px solid #FDDCBA;padding:7px 0;overflow:hidden;}
.ticker-inner{max-width:1280px;margin:0 auto;padding:0 24px;display:flex;align-items:center;gap:14px;}
.ticker-tag{background:var(--accent);color:#fff;padding:2px 10px;border-radius:4px;font-size:11px;font-weight:700;white-space:nowrap;flex-shrink:0;}
.ticker-track{display:flex;animation:tick 35s linear infinite;white-space:nowrap;}
.ticker-track:hover{animation-play-state:paused;}
.ti{font-size:13px;color:var(--ad);font-weight:500;padding-right:40px;}
.ti::before{content:'›';margin-right:6px;opacity:.6;}
@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ── BREADCRUMB ── */
.breadcrumb{max-width:1280px;margin:0 auto;padding:14px 24px 0;font-size:12.5px;color:var(--muted);}
.breadcrumb a{color:var(--accent);text-decoration:none;}
.breadcrumb a:hover{text-decoration:underline;}

/* ── PAGE LAYOUT ── */
.page{max-width:1280px;margin:0 auto;padding:20px 24px 40px;display:grid;grid-template-columns:1fr 300px;gap:22px;align-items:start;}
@media(max-width:1024px){.page{grid-template-columns:1fr;}}

/* ── MAIN AREA ── */
/* Page header */
.main-hdr{background:linear-gradient(135deg,var(--dark) 0%,#2D2D5E 100%);border-radius:14px;padding:28px 32px;margin-bottom:18px;position:relative;overflow:hidden;}
.main-hdr::after{content:'';position:absolute;right:-60px;top:-60px;width:240px;height:240px;background:rgba(255,255,255,0.03);border-radius:50%;}
.mh-tag{display:inline-flex;align-items:center;gap:5px;background:rgba(253,186,116,.15);border:1px solid rgba(253,186,116,.3);color:#FDBA74;padding:3px 12px;border-radius:20px;font-size:11px;font-weight:700;margin-bottom:10px;}
.mh-title{font-family:'Syne',sans-serif;font-size:clamp(20px,3vw,28px);font-weight:800;color:#fff;margin-bottom:6px;}
.mh-title span{color:#FDBA74;}
.mh-sub{color:#94A3B8;font-size:13.5px;}
.mh-stats{display:flex;gap:22px;margin-top:16px;flex-wrap:wrap;}
.mhs{text-align:center;}
.mhs-n{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#FDBA74;}
.mhs-l{font-size:11px;color:#64748B;}

/* Filter bar */
.filter-bar{background:#fff;border:1.5px solid var(--border);border-radius:var(--r);padding:14px 16px;margin-bottom:16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
.fb-label{font-size:12px;font-weight:700;color:var(--muted);white-space:nowrap;}
.filter-chips{display:flex;gap:7px;flex-wrap:wrap;flex:1;}
.chip{padding:5px 13px;border:1.5px solid var(--border);border-radius:20px;font-size:12.5px;font-weight:600;cursor:pointer;transition:all .15s;background:#fff;color:var(--muted);white-space:nowrap;}
.chip:hover{border-color:var(--accent);color:var(--accent);}
.chip.on{background:var(--accent);border-color:var(--accent);color:#fff;}
.fb-search{display:flex;border:1.5px solid var(--border);border-radius:7px;overflow:hidden;flex-shrink:0;}
.fb-search input{padding:7px 12px;font-size:13px;border:none;outline:none;width:180px;font-family:'Figtree',sans-serif;}
.fb-search input::placeholder{color:#9CA3AF;}
@media(max-width:600px){.fb-search{width:100%;}.fb-search input{flex:1;width:auto;}}

/* Sort bar */
.sort-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;}
.sort-left{font-size:13px;color:var(--muted);}
.sort-left strong{color:var(--dark);}
.sort-right{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);}
.sort-right select{padding:5px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:13px;font-family:'Figtree',sans-serif;outline:none;color:var(--dark);background:#fff;}

/* Job cards */
.job-list{display:flex;flex-direction:column;gap:10px;}
.job-card{background:#fff;border:1.5px solid var(--border);border-radius:var(--r);padding:0;overflow:hidden;transition:all .15s;cursor:pointer;}
.job-card:hover{border-color:var(--accent);box-shadow:0 4px 20px rgba(232,93,4,.08);transform:translateY(-1px);}
.jc-inner{padding:16px 18px;}
.jc-top{display:flex;align-items:flex-start;gap:14px;}
.jc-org-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.jc-info{flex:1;min-width:0;}
.jc-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--dark);margin-bottom:4px;line-height:1.3;}
.jc-title a{color:inherit;text-decoration:none;}
.jc-title a:hover{color:var(--accent);}
.jc-org{font-size:12.5px;color:var(--muted);margin-bottom:8px;}
.jc-tags{display:flex;gap:6px;flex-wrap:wrap;}
.tag{font-size:11px;font-weight:700;padding:2px 9px;border-radius:20px;}
.tag-cat{background:var(--bl);color:var(--blue);}
.tag-state{background:var(--gl);color:var(--green);}
.tag-edu{background:var(--pl);color:var(--purple);}
.tag-new{background:#FEF2F2;color:var(--red);}
.tag-hot{background:var(--al);color:var(--ad);}
.tag-ext{background:#F0FDF4;color:#16A34A;}
.tag-reopen{background:#EFF6FF;color:#2563EB;}
.jc-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;}
.jc-vac{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--dark);}
.jc-vac span{font-size:10px;font-weight:600;color:var(--muted);font-family:'Figtree',sans-serif;display:block;text-align:right;}
.jc-foot{border-top:1px solid var(--bg3);padding:10px 18px;display:flex;align-items:center;justify-content:space-between;background:var(--bg2);flex-wrap:wrap;gap:8px;}
.jf-dates{display:flex;gap:16px;flex-wrap:wrap;}
.jf-date{font-size:12px;color:var(--muted);}
.jf-date strong{color:var(--dark);font-weight:600;}
.jf-date.urgent strong{color:var(--red);}
.jf-btns{display:flex;gap:8px;}
.btn-apply{background:linear-gradient(135deg,#E85D04,#C44D00);color:#fff;padding:7px 18px;border-radius:7px;font-size:12.5px;font-weight:700;text-decoration:none;white-space:nowrap;transition:opacity .15s;}
.btn-apply:hover{opacity:.88;}
.btn-detail{background:#fff;border:1.5px solid var(--border);color:var(--muted);padding:6px 14px;border-radius:7px;font-size:12.5px;font-weight:600;text-decoration:none;white-space:nowrap;transition:all .15s;}
.btn-detail:hover{border-color:var(--accent);color:var(--accent);}

/* Urgency strip */
.job-card.urgent-card{border-left:4px solid var(--red);}
.job-card.hot-card{border-left:4px solid var(--accent);}

/* Pagination */
.pagination{display:flex;gap:6px;align-items:center;justify-content:center;margin-top:24px;flex-wrap:wrap;}
.pg-btn{width:36px;height:36px;border-radius:8px;border:1.5px solid var(--border);background:#fff;font-size:13.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:all .15s;font-family:'Figtree',sans-serif;}
.pg-btn:hover{border-color:var(--accent);color:var(--accent);}
.pg-btn.act{background:var(--accent);border-color:var(--accent);color:#fff;}
.pg-btn.pg-nav{width:auto;padding:0 14px;gap:4px;}

/* No results */
.no-results{background:#fff;border:1.5px solid var(--border);border-radius:var(--r);padding:48px;text-align:center;}
.no-results h3{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;color:var(--dark);margin-bottom:8px;}
.no-results p{color:var(--muted);font-size:14px;}

/* ── SIDEBAR ── */
.sidebar{display:flex;flex-direction:column;gap:16px;}
.scard{background:#fff;border:1.5px solid var(--border);border-radius:var(--r);overflow:hidden;}
.scard-hdr{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;}
.scard-hdr-title{font-family:'Syne',sans-serif;font-size:13.5px;font-weight:700;color:var(--dark);}
.scard-body{padding:12px 16px;}

/* Sidebar quick filters */
.qf-list{display:flex;flex-direction:column;gap:4px;}
.qf-item{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--bg3);cursor:pointer;text-decoration:none;}
.qf-item:last-child{border-bottom:none;}
.qf-name{font-size:13px;color:var(--dark);font-weight:500;display:flex;align-items:center;gap:8px;}
.qf-count{font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;}
.qf-item:hover .qf-name{color:var(--accent);}

/* Sidebar deadline list */
.dl-list{display:flex;flex-direction:column;gap:8px;}
.dl-item{display:flex;align-items:flex-start;gap:10px;padding:8px;border-radius:8px;background:var(--bg2);}
.dl-date{background:var(--red);color:#fff;border-radius:7px;padding:5px 8px;text-align:center;flex-shrink:0;min-width:42px;}
.dl-day{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;line-height:1;}
.dl-mon{font-size:10px;font-weight:700;opacity:.9;}
.dl-title{font-size:12.5px;color:var(--dark);line-height:1.4;font-weight:500;}
.dl-org{font-size:11px;color:var(--muted);}

/* Sidebar mock test promo */
.mock-promo{background:linear-gradient(135deg,var(--dark),#2D1B69);border-radius:var(--r);padding:18px;text-align:center;}
.mp-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff;margin-bottom:6px;}
.mp-sub{font-size:12.5px;color:#94A3B8;margin-bottom:14px;}
.mp-btn{display:inline-block;background:linear-gradient(135deg,#E85D04,#C44D00);color:#fff;padding:9px 20px;border-radius:8px;font-size:13px;font-weight:700;text-decoration:none;}

/* Sidebar notify */
.notify-box{padding:14px 16px;}
.nb-title{font-size:13px;font-weight:700;color:var(--dark);margin-bottom:8px;}
.nb-input{display:flex;gap:6px;}
.nb-input input{flex:1;padding:8px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:13px;font-family:'Figtree',sans-serif;outline:none;}
.nb-input input:focus{border-color:var(--accent);}
.nb-btn{background:var(--accent);color:#fff;border:none;padding:8px 14px;border-radius:7px;font-size:12.5px;font-weight:700;cursor:pointer;font-family:'Figtree',sans-serif;white-space:nowrap;}

/* Footer */
footer{background:var(--dark);color:#94A3B8;margin-top:0;}
.footer-bottom{max-width:1280px;margin:0 auto;padding:18px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;font-size:12.5px;}
.footer-bottom a{color:#64748B;text-decoration:none;margin-left:12px;}
.footer-bottom a:hover{color:#FDBA74;}

/* Responsive */
@media(max-width:600px){.jc-right{display:none;}.jf-dates{display:none;}}

/* Loading skeleton */
.skeleton{background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.4s infinite;border-radius:4px;}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
</style>
</head>
