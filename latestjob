/* ══════════════════════════════════════
   STATE
══════════════════════════════════════ */
let filteredJobs = [...JOBS];
let currentFilter = 'all';
let searchQuery = '';
let currentPage = 1;
const PER_PAGE = 15;

/* ══════════════════════════════════════
   RENDER
══════════════════════════════════════ */
function renderJobs() {
  const list = document.getElementById('job-list');
  const start = (currentPage - 1) * PER_PAGE;
  const pageJobs = filteredJobs.slice(start, start + PER_PAGE);

  document.getElementById('showing-count').textContent = filteredJobs.length;
  document.getElementById('total-count').textContent = filteredJobs.length;

  if (!pageJobs.length) {
    list.innerHTML = `<div class="no-results"><h3>No jobs found</h3><p>Try a different filter or search term.</p></div>`;
    document.getElementById('pagination').innerHTML = '';
    return;
  }

  const badgeMap = {
    new: '<span class="tag tag-new">NEW</span>',
    hot: '<span class="tag tag-hot">🔥 HOT</span>',
    ext: '<span class="tag tag-ext">EXTENDED</span>',
    reopen: '<span class="tag tag-reopen">RE-OPEN</span>',
  };

  const iconBg = {
    SSC:'#FFF3EB', Railway:'#ECFDF5', Banking:'#F5F3FF', Defence:'#FEF2F2',
    UPSC:'#EFF6FF', 'State PSC':'#F0F2F8', Teaching:'#EFF6FF', Police:'#FEF2F2', Court:'#F5F3FF'
  };

  list.innerHTML = pageJobs.map(j => {
    const isUrgent = j.badge !== 'new' && j.badge !== 'hot' && j.lastDate && daysLeft(j.lastDate) <= 5;
    const urgentClass = j.badge === 'hot' ? 'hot-card' : (isUrgent ? 'urgent-card' : '');
    const vac = j.vacancies ? j.vacancies.toLocaleString('en-IN') + '<span>Vacancies</span>' : '<span>Various</span>';
    const urgentDate = isUrgent ? 'urgent' : '';
    const dLeft = j.lastDate !== 'Closed' && j.lastDate !== 'Ongoing' ? daysLeftLabel(j.lastDate) : '';
    return `
    <div class="job-card ${urgentClass}" onclick="openJob('${j.officialLink}')">
      <div class="jc-inner">
        <div class="jc-top">
          <div class="jc-org-icon" style="background:${iconBg[j.cat]||'#F7F8FC'}">${j.icon}</div>
          <div class="jc-info">
            <div class="jc-title"><a href="${j.officialLink}" target="_blank" onclick="event.stopPropagation()">${j.title}</a></div>
            <div class="jc-org">${j.org}</div>
            <div class="jc-tags">
              <span class="tag tag-cat">${j.cat}</span>
              <span class="tag tag-state">${j.state}</span>
              <span class="tag tag-edu">${j.edu}</span>
              ${j.badge ? badgeMap[j.badge]||'' : ''}
              ${dLeft ? `<span class="tag" style="background:#FEF2F2;color:#DC2626;">${dLeft}</span>` : ''}
            </div>
          </div>
          <div class="jc-right">
            <div class="jc-vac">${vac}</div>
            <a href="${j.officialLink}" target="_blank" onclick="event.stopPropagation()" class="btn-apply">Apply Online</a>
          </div>
        </div>
      </div>
      <div class="jc-foot">
        <div class="jf-dates">
          <div class="jf-date"><strong>Start:</strong> ${j.applyStart}</div>
          <div class="jf-date ${urgentDate}"><strong>Last Date:</strong> ${j.lastDate}</div>
          ${j.examDate ? `<div class="jf-date"><strong>Exam:</strong> ${j.examDate}</div>` : ''}
          ${j.salary ? `<div class="jf-date"><strong>Salary:</strong> ${j.salary}</div>` : ''}
        </div>
        <div class="jf-btns">
          <a href="#" onclick="event.stopPropagation();showDetail(${j.id})" class="btn-detail">Details</a>
          <a href="${j.officialLink}" target="_blank" onclick="event.stopPropagation()" class="btn-apply">Apply →</a>
        </div>
      </div>
    </div>`;
  }).join('');

  renderPagination();
}

function daysLeft(dateStr) {
  try {
    const parts = dateStr.split(' ');
    const months = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
    const d = new Date(parseInt(parts[2]), months[parts[1]], parseInt(parts[0]));
    return Math.floor((d - new Date()) / 86400000);
  } catch { return 999; }
}

function daysLeftLabel(dateStr) {
  const d = daysLeft(dateStr);
  if (d < 0) return '';
  if (d === 0) return '⚠️ Last Day!';
  if (d <= 3) return `⚠️ ${d} days left`;
  if (d <= 7) return `${d} days left`;
  return '';
}

function openJob(url) { window.open(url, '_blank'); }

function showDetail(id) {
  const j = JOBS.find(x => x.id === id);
  if (!j) return;
  alert(`📋 ${j.title}\n\nOrganization: ${j.org}\nVacancies: ${j.vacancies ? j.vacancies.toLocaleString('en-IN') : 'Various'}\nEducation: ${j.edu}\nApply Start: ${j.applyStart}\nLast Date: ${j.lastDate}\nExam Date: ${j.examDate||'TBA'}\nFee: ${j.fee||'See Official'}\nSalary: ${j.salary||'As per rules'}\n\nFor full details visit: ${j.officialLink}`);
}

/* PAGINATION */
function renderPagination() {
  const total = Math.ceil(filteredJobs.length / PER_PAGE);
  if (total <= 1) { document.getElementById('pagination').innerHTML = ''; return; }
  let html = `<button class="pg-btn pg-nav" onclick="goPage(${Math.max(1,currentPage-1)})">← Prev</button>`;
  for (let i = 1; i <= total; i++) {
    if (i === 1 || i === total || Math.abs(i - currentPage) <= 2) {
      html += `<button class="pg-btn${i===currentPage?' act':''}" onclick="goPage(${i})">${i}</button>`;
    } else if (Math.abs(i - currentPage) === 3) {
      html += `<span style="padding:0 4px;color:var(--muted);">…</span>`;
    }
  }
  html += `<button class="pg-btn pg-nav" onclick="goPage(${Math.min(total,currentPage+1)})">Next →</button>`;
  document.getElementById('pagination').innerHTML = html;
}

function goPage(p) { currentPage = p; renderJobs(); window.scrollTo({top:300,behavior:'smooth'}); }

/* FILTER */
function setFilter(cat, el) {
  currentFilter = cat;
  currentPage = 1;
  if (el) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('on'));
    el.classList.add('on');
  }
  applyFilters();
}

function liveSearch(q) {
  searchQuery = q.toLowerCase();
  currentPage = 1;
  // sync both search boxes
  document.getElementById('nav-search').value = q;
  document.getElementById('main-search').value = q;
  applyFilters();
}

function sortJobs(by) {
  if (by === 'newest') filteredJobs.sort((a,b) => b.id - a.id);
  else if (by === 'deadline') filteredJobs.sort((a,b) => daysLeft(a.lastDate) - daysLeft(b.lastDate));
  else if (by === 'vacancies') filteredJobs.sort((a,b) => (b.vacancies||0) - (a.vacancies||0));
  renderJobs();
}

function applyFilters() {
  filteredJobs = JOBS.filter(j => {
    const catMatch = currentFilter === 'all' || j.cat === currentFilter;
    const searchMatch = !searchQuery || j.title.toLowerCase().includes(searchQuery) || j.org.toLowerCase().includes(searchQuery) || j.state.toLowerCase().includes(searchQuery) || j.cat.toLowerCase().includes(searchQuery);
    return catMatch && searchMatch;
  });
  renderJobs();
}

function subscribe() {
  const email = document.getElementById('notify-email').value;
  if (!email || !/\S+@\S+\.\S+/.test(email)) { alert('Please enter a valid email address.'); return; }
  document.getElementById('sub-msg').style.display = 'block';
  document.getElementById('notify-email').value = '';
}

// Init
renderJobs();
</script>
